package base

import "github.com/luism2302/goNances/views/components"

templ LayoutWelcome() {
	@components.Header("Welcome")
	<body class="bg-[#222831]">
		<main>
			<div class="flex flex-col justify-center items-center gap-y-5 w-screen h-screen" id="modal-container">
				<div>
					<h1 class="font-extrabold font-mono text-5xl text-[#EEEEEE]">GoNances</h1>
				</div>
				<div class="h-1/20 w-1/6">
					<button hx-get="/login" hx-trigger="click" hx-target="#modal-container" hx-swap="innerHTML" class="bg-[#FFD369] rounded-md text-[#222831] font-bold h-full  w-full" type="button">Login</button>
				</div>
				<div class="h-1/20 w-1/6">
					<button hx-get="/signup" hx-trigger="click" hx-target="#modal-container" hx-swap="innerHTML" class="bg-[#FFD369] rounded-md text-[#222831] font-bold h-full w-full" type="button">Sign Up</button>
				</div>
			</div>
		</main>
	</body>
}

templ LayoutDashboard(user string) {
	@components.Header("Dashboard")
	<body class="bg-[#222831]">
		<main>
			<div class="flex flex-col w-screen h-screen">
				@components.NavBar()
				<div class="h-screen w-screen p-5" id="content"></div>
			</div>
		</main>
	</body>
}
